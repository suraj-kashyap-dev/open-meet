# ─── API server (apps/server/.env) ─────────────────────────────────
NODE_ENV=development
PORT=3001
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/meetclone
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_EXPIRY=60m
JWT_REFRESH_EXPIRY=7d

# Admin (separate from user JWT — short-lived, no refresh)
ADMIN_JWT_ACCESS_SECRET=change-me-admin-access
ADMIN_JWT_ACCESS_EXPIRY=2h

# Default admin auto-created on first boot if no admin exists
DEFAULT_ADMIN_EMAIL=admin@open-meet.local
DEFAULT_ADMIN_PASSWORD=admin12345
DEFAULT_ADMIN_NAME=Site Admin

# Attachment storage. Provide S3_BUCKET (and credentials) to enable S3.
# When S3_BUCKET is empty, attachments are stored on local disk under LOCAL_STORAGE_DIR
# and served via /api/uploads/files/* (authenticated).
# S3_BUCKET=
# S3_REGION=us-east-1
# S3_ENDPOINT=                       # e.g. https://s3.amazonaws.com or http://localhost:9000 (MinIO)
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_PUBLIC_URL=                     # CDN/public host override; defaults to endpoint
# S3_FORCE_PATH_STYLE=false          # set true for MinIO / non-AWS endpoints
LOCAL_STORAGE_DIR=./uploads
UPLOAD_MAX_SIZE_BYTES=26214400
# Used to build absolute URLs for locally-stored attachments. The browser fetches
# images/videos from this origin directly (not via the Next.js proxy), so it must
# match how clients reach the API. Defaults to http://localhost:3001 for dev.
API_PUBLIC_URL=http://localhost:3001

# LiveKit
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
LIVEKIT_HOST=ws://localhost:7880

# CORS / front-end origin
FRONTEND_URL=http://localhost:3000

# Mail (MailHog in dev)
SMTP_HOST=localhost
SMTP_PORT=1025

# ─── Web (apps/web/.env.local) ──────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=http://localhost:3001
NEXT_PUBLIC_LIVEKIT_URL=ws://localhost:7880
