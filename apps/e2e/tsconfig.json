{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "preserve",
    "types": ["node", "@playwright/test", "vitest/globals"],
    "noEmit": true,
    "noUncheckedIndexedAccess": false,
    "baseUrl": ".",
    "paths": {
      "@/*": ["../web/*"]
    }
  },
  "include": [
    "tests/**/*",
    "playwright.config.ts",
    "vitest.config.ts",
    "fixtures/**/*"
  ],
  "exclude": ["node_modules", "playwright-report", "test-results"]
}
