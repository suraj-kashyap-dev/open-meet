NODE_ENV=development
PORT=3001
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/meetclone
REDIS_URL=redis://localhost:6379

# JWT (user)
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_EXPIRY=7d
JWT_REFRESH_EXPIRY=7d

# Admin (separate from user JWT — short-lived, no refresh)
ADMIN_JWT_ACCESS_SECRET=change-me-admin-access
ADMIN_JWT_ACCESS_EXPIRY=2h

# Default admin auto-created on first boot if no admin exists
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=admin12345
DEFAULT_ADMIN_NAME=Example

# Storage
LOCAL_STORAGE_DIR=./uploads
UPLOAD_MAX_SIZE_BYTES=26214400

API_PUBLIC_URL=http://localhost:3001

# LiveKit
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
LIVEKIT_HOST=ws://localhost:7880

# Recording (LiveKit Egress)
# RECORDING_EGRESS_FILEPATH_PREFIX is the path the *egress container* writes
# to (its mounted volume). RECORDING_STORAGE_SUBDIR is the path the *API*
# reads from, under LOCAL_STORAGE_DIR. Both must point at the same physical
# directory via the docker-compose bind mounts.
RECORDING_EGRESS_FILEPATH_PREFIX=/out
RECORDING_STORAGE_SUBDIR=recordings
RECORDING_LAYOUT=grid

# CORS / front-end origin
FRONTEND_URL=http://localhost:3000

# Mail
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
MAIL_FROM=open-meet <noreply@open-meet.local>
