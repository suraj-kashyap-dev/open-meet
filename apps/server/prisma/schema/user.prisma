model User {
  id              String        @id @default(cuid())
  name            String
  email           String        @unique
  passwordHash    String?
  googleId        String?       @unique
  avatarKey       String?
  avatarUrl       String?
  timezone        String        @default("UTC")
  language        String        @default("en")
  bio             String?
  chatDisabled    Boolean       @default(false)
  emailVerifiedAt DateTime?
  roleRecordId    String
  roleRecord      UserRoleRecord @relation(fields: [roleRecordId], references: [id], onDelete: Restrict)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  settings        UserSettings?
  meetings        Participant[]
  messages        Message[]
  hostedMeetings  Meeting[]     @relation("host")

  teamMemberships         TeamMember[]
  conversationMemberships ConversationMember[]
  chatMessages            ChatMessage[]
  messageReactions        MessageReaction[]
  messageMentions         MessageMention[]
  pinnedMessages          PinnedMessage[]
  savedMessages           SavedMessage[]
  presence                UserPresence?
  pollVotes               PollVote[]

  @@index([email])
  @@index([googleId])
  @@index([roleRecordId])
}

model UserSettings {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  defaultMicMuted     Boolean            @default(false)
  defaultCameraOff    Boolean            @default(false)
  defaultView         MeetingDefaultView @default(GALLERY)
  enableJoinSound     Boolean            @default(true)
  enableNotifications Boolean            @default(true)

  showEmailToParticipants Boolean           @default(true)
  allowDirectMessages     Boolean           @default(true)
  profileVisibility       ProfileVisibility @default(PARTICIPANTS_ONLY)
  shareUsageData          Boolean           @default(false)

  accentColorOverride String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum MeetingDefaultView {
  GALLERY
  SPEAKER
}

enum ProfileVisibility {
  PUBLIC
  PARTICIPANTS_ONLY
  PRIVATE
}
