model Admin {
  id           String           @id @default(cuid())
  email        String           @unique
  name         String
  passwordHash String
  roleRecordId String
  roleRecord   AdminRoleRecord  @relation(fields: [roleRecordId], references: [id], onDelete: Restrict)
  avatarKey    String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  lastLoginAt  DateTime?

  invitesSent          AdminInvite[]
  userInvitesSent      UserInvite[]
  conversationsCreated Conversation[]
  departmentsResponsibleFor Department[] @relation("DepartmentResponsible")

  @@index([email])
  @@index([roleRecordId])
}

model AdminInvite {
  id           String           @id @default(cuid())
  email        String           @unique
  name         String
  roleRecordId String?
  roleRecord   AdminRoleRecord? @relation(fields: [roleRecordId], references: [id], onDelete: SetNull)
  tokenHash    String           @unique
  expiresAt    DateTime
  invitedById  String?
  invitedBy    Admin?           @relation(fields: [invitedById], references: [id], onDelete: SetNull)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([email])
  @@index([roleRecordId])
}

model WorkspaceSettings {
  id                  String   @id @default("default")
  appName             String   @default("Open Meet")
  logoKey             String?
  defaultMeetingTitle String   @default("Untitled meeting")
  allowGuestJoin      Boolean  @default(true)
  maxMeetingMinutes   Int?
  banner              String?
  // Brand accent (CSS var driver). Either a preset slug ("indigo", "blue",
  // "green", "purple", "rose", "amber", "teal") or a `#RRGGBB` hex.
  accentColor         String   @default("indigo")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}
