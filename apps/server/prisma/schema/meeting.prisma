model Meeting {
  id           String          @id @default(cuid())
  code         String          @unique
  title        String?
  hostId       String
  host         User            @relation("host", fields: [hostId], references: [id], onDelete: Cascade)
  status       MeetingStatus   @default(WAITING)
  settings     Json            @default("{}")
  scheduledFor DateTime?
  recurrence   String?
  durationMin  Int?
  startedAt    DateTime?
  endedAt      DateTime?
  createdAt    DateTime        @default(now())
  participants Participant[]
  messages     Message[]
  recordings   Recording[]
  invites      MeetingInvite[]

  @@index([hostId])
  @@index([status])
  @@index([scheduledFor])
}

model MeetingInvite {
  id        String    @id @default(cuid())
  meetingId String
  meeting   Meeting   @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  email     String
  sentAt    DateTime?
  createdAt DateTime  @default(now())

  @@unique([meetingId, email])
  @@index([meetingId])
}

model Participant {
  id        String          @id @default(cuid())
  meetingId String
  meeting   Meeting         @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      ParticipantRole @default(GUEST)
  joinedAt  DateTime        @default(now())
  leftAt    DateTime?

  @@unique([meetingId, userId])
  @@index([meetingId])
}

enum MeetingStatus {
  WAITING
  ACTIVE
  ENDED
}

enum ParticipantRole {
  HOST
  GUEST
}
