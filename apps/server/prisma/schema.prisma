generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String        @id @default(cuid())
  name           String
  email          String        @unique
  passwordHash   String
  avatarKey      String?
  timezone       String        @default("UTC")
  language       String        @default("en")
  bio            String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  settings       UserSettings?
  meetings       Participant[]
  messages       Message[]
  hostedMeetings Meeting[]     @relation("host")

  @@index([email])
}

model UserSettings {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  defaultMicMuted     Boolean            @default(false)
  defaultCameraOff    Boolean            @default(false)
  defaultView         MeetingDefaultView @default(GALLERY)
  enableJoinSound     Boolean            @default(true)
  enableNotifications Boolean            @default(true)

  showEmailToParticipants Boolean           @default(true)
  allowDirectMessages     Boolean           @default(true)
  profileVisibility       ProfileVisibility @default(PARTICIPANTS_ONLY)
  shareUsageData          Boolean           @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum MeetingDefaultView {
  GALLERY
  SPEAKER
}

enum ProfileVisibility {
  PUBLIC
  PARTICIPANTS_ONLY
  PRIVATE
}

model Meeting {
  id            String          @id @default(cuid())
  code          String          @unique
  title         String?
  hostId        String
  host          User            @relation("host", fields: [hostId], references: [id], onDelete: Cascade)
  status        MeetingStatus   @default(WAITING)
  settings      Json            @default("{}")
  scheduledFor  DateTime?
  recurrence    String?
  durationMin   Int?
  startedAt     DateTime?
  endedAt       DateTime?
  createdAt     DateTime        @default(now())
  participants  Participant[]
  messages      Message[]
  recordings    Recording[]
  invites       MeetingInvite[]

  @@index([hostId])
  @@index([status])
  @@index([scheduledFor])
}

model MeetingInvite {
  id        String    @id @default(cuid())
  meetingId String
  meeting   Meeting   @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  email     String
  sentAt    DateTime?
  createdAt DateTime  @default(now())

  @@unique([meetingId, email])
  @@index([meetingId])
}

model Participant {
  id        String          @id @default(cuid())
  meetingId String
  meeting   Meeting         @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      ParticipantRole @default(GUEST)
  joinedAt  DateTime        @default(now())
  leftAt    DateTime?

  @@unique([meetingId, userId])
  @@index([meetingId])
}

model Message {
  id          String       @id @default(cuid())
  meetingId   String
  meeting     Meeting      @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  senderId    String
  sender      User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  content     String
  sentAt      DateTime     @default(now())
  attachments Attachment[]

  @@index([meetingId, sentAt])
}

model Attachment {
  id         String   @id @default(cuid())
  messageId  String?
  message    Message? @relation(fields: [messageId], references: [id], onDelete: Cascade)
  uploaderId String
  storageKey String   @unique
  url        String
  mime       String
  size       Int
  width      Int?
  height     Int?
  createdAt  DateTime @default(now())

  @@index([messageId])
  @@index([uploaderId])
}

model Recording {
  id           String          @id @default(cuid())
  meetingId    String
  meeting      Meeting         @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  egressId     String          @unique
  status       RecordingStatus @default(RECORDING)
  startedById  String
  storageKey   String?
  url          String?
  mime         String          @default("video/mp4")
  duration     Int             @default(0)
  size         BigInt          @default(0)
  error        String?
  startedAt    DateTime        @default(now())
  endedAt      DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([meetingId])
  @@index([status])
}

enum RecordingStatus {
  RECORDING
  STOPPING
  COMPLETED
  FAILED
}

enum MeetingStatus {
  WAITING
  ACTIVE
  ENDED
}

enum ParticipantRole {
  HOST
  GUEST
}

model Admin {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  passwordHash String
  role         AdminRole @default(ADMIN)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lastLoginAt  DateTime?

  @@index([email])
}

enum AdminRole {
  SUPERADMIN
  ADMIN
}

model WorkspaceSettings {
  id                  String   @id @default("default")
  defaultMeetingTitle String   @default("Untitled meeting")
  allowGuestJoin      Boolean  @default(true)
  maxMeetingMinutes   Int?
  banner              String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}
