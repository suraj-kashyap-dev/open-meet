{
  "name": "open-meet",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.16.0",
  "scripts": {
    "build": "turbo run build",
    "start": "turbo run start --filter=./apps/*",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint -- --fix",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "i18n:verify": "tsx scripts/i18n/verify-translations.ts",
    "clean": "turbo run clean && rimraf node_modules",
    "setup": "./setup.sh",
    "db:reset": "pnpm --filter @open-meet/server exec prisma migrate reset --skip-seed",
    "db:wipe": "pnpm --filter @open-meet/server exec prisma migrate reset --force --skip-seed",
    "db:studio": "pnpm --filter @open-meet/server exec prisma studio"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.5",
    "eslint": "^9.18.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "tsx": "^4.22.0",
    "turbo": "^2.3.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.20.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
