{
  "name": "open-meet",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.16.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "clean": "turbo run clean && rimraf node_modules",
    "app:install": "tsx scripts/install.ts",
    "db:reset": "pnpm --filter @open-meet/server exec prisma migrate reset --skip-seed",
    "db:wipe": "pnpm --filter @open-meet/server exec prisma migrate reset --force --skip-seed",
    "db:studio": "pnpm --filter @open-meet/server exec prisma studio"
  },
  "devDependencies": {
    "@clack/prompts": "^0.8.2",
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.5",
    "eslint": "^9.18.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "turbo": "^2.3.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.20.0",
    "yaml": "^2.6.1"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "@scarf/scarf",
      "argon2",
      "esbuild",
      "msgpackr-extract",
      "prisma"
    ]
  }
}
